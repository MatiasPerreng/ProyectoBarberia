# Copiar a .env y configurar con tus valores reales

# CORS: orígenes desde los que el navegador puede llamar al API (mismo patrón que ProyectoBurgers).
# Si abrís el front desde un host que no esté listado, el sync de Mercado Pago falla (el POST ni llega al backend).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://tu-dominio.com
# Opcional: regex para IPs LAN, p. ej. ^https?://[0-9.]+:5173$
# CORS_ORIGIN_REGEX=

# Base de datos
DATABASE_URL=mysql+pymysql://usuario:password@localhost:3306/barber

# JWT (OBLIGATORIO en producción - generar con: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=tu_secret_muy_largo_y_seguro_aqui

# Solo para desarrollo: activar endpoint /test-email
# ENABLE_TEST_EMAIL=false

# --- Mercado Pago (pago anticipado en agenda — Checkout Pro) ---
# Panel: https://www.mercadopago.com.uy/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
# Solo Checkout Pro con el token (recomendado en dev). Poné checkout_pro para no usar link fijo
# ni heredar MERCADOPAGO_LINK_PAGO de variables globales de Windows (otro negocio).
MERCADOPAGO_LINK_PAGO=checkout_pro
# Misma URL que usás en el navegador para abrir el front (Vite suele ser 5173).
PUBLIC_FRONTEND_URL=http://localhost:5173
# Webhook (producción / ngrok): https://tu-dominio.com
BACKEND_PUBLIC_URL=
MERCADOPAGO_WEBHOOK_SECRET=
# Opcional: descripción en resumen de tarjeta (máx. 22 caracteres).
# MERCADOPAGO_STATEMENT_DESCRIPTOR=KING BARBER

# Solo referencia (opcional): usuario/contraseña del COMPRADOR de prueba en MP sandbox.
# El backend no las usa; sirven para recordar con qué cuenta probás el pago en el sitio de MP.
# Crear comprador en: Developers → tu aplicación → Usuarios de prueba.
# MERCADOPAGO_TEST_BUYER_USER=
# MERCADOPAGO_TEST_BUYER_PASSWORD=
