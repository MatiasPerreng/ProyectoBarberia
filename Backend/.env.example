# Copiar a .env y configurar con tus valores reales

# Base de datos
DATABASE_URL=mysql+pymysql://usuario:password@localhost:3306/barber

# JWT (OBLIGATORIO en producción - generar con: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=tu_secret_muy_largo_y_seguro_aqui

# Solo para desarrollo: activar endpoint /test-email
# ENABLE_TEST_EMAIL=false

# --- Correo (FastAPI-Mail; Gmail = contraseña de aplicación, no la de la cuenta) ---
# MAIL_ENABLED=true
# MAIL_USERNAME=tucorreo@gmail.com
# MAIL_PASSWORD=xxxx xxxx xxxx xxxx   # 16 caracteres de «Contraseña de aplicaciones» Google
# MAIL_FROM=tucorreo@gmail.com       # conviene que coincida con MAIL_USERNAME en Gmail
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_STARTTLS=true
# MAIL_SSL_TLS=false
# Si SMTP devuelve 534 WebLoginRequired: https://support.google.com/accounts/answer/185833

# --- Mercado Pago (Checkout Pro sobre visitas) ---
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
# Con token que empieza en TEST-, el API no manda payer.email (evita errores de sandbox al pagar con TESTUSER).
# Firma HMAC de notificaciones (panel MP → Webhooks → clave secreta).
# MERCADOPAGO_WEBHOOK_SECRET=
# Validación x-signature: con MERCADOPAGO_WEBHOOK_SECRET definido, por defecto se exige firma válida.
# false = no validar (solo emergencias). true = forzar validación aunque no haya secret (fallará).
# MERCADOPAGO_WEBHOOK_ENFORCE_SIGNATURE=
# Log completo headers/body (no usar en prod salvo diagnóstico puntual):
# MERCADOPAGO_WEBHOOK_VERBOSE_DEBUG=false
# print() de headers/body en webhook (default true en dev; en prod: false)
# MERCADOPAGO_WEBHOOK_CONSOLE_DIAG=true
# En producción: true fuerza que exista secret (si no, 500) y rechaza peticiones sin firma válida (401).
# MERCADOPAGO_WEBHOOK_STRICT=false
# --- URLs públicas (al cambiar DNS o dominio, actualizá estas y reiniciá el backend) ---
# Front: misma base que escribís en el navegador (Mercado Pago back_urls al crear cada preferencia).
# Con Vite + SSL local (puerto 5174):
# PUBLIC_FRONTEND_URL=https://localhost:5174
# Producción KingBarber:
# PUBLIC_FRONTEND_URL=https://kingbarber.webhop.net
# Override solo para MP si el front difiere del resto del .env:
# MERCADOPAGO_RETURN_FRONTEND_URL=https://kingbarber.webhop.net
# API local (Vite, fetch interno). Para MP en dev dejá esto en 127.0.0.1 y usá el túnel abajo.
# BACKEND_PUBLIC_URL=http://127.0.0.1:8000
# Solo para notification_url de MP: ngrok HTTPS al puerto del FastAPI (prioridad sobre BACKEND_PUBLIC_URL).
# MERCADOPAGO_TUNNEL_URL=https://abc123.ngrok-free.app
# En producción: mismo valor que el API público con SSL (podés omitir MERCADOPAGO_TUNNEL_URL):
# BACKEND_PUBLIC_URL=https://kingbarber.webhop.net/api
# CORS: orígenes extra (coma). En prod con puerto 443 incluí el/los origin exactos del front.
# CORS_ORIGINS=https://kingbarber.webhop.net
# URL del comprobante en panel admin ({payment_id} se reemplaza). Ajustá dominio si hace falta.
# MERCADOPAGO_COMPROBANTE_URL=https://www.mercadopago.com.uy/tools/receipt-view/{payment_id}
# Minutos de validez del link de pago (preferencia MP + cancelación pendiente en BD si no hay IPN). Default 10.
# MERCADOPAGO_PREFERENCE_EXPIRATION_MINUTES=10
