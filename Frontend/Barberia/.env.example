# Copiar a .env (opcional). Variables VITE_* solo se leen al arrancar Vite.

# URL del backend FastAPI. En producción KingBarber se usa el proxy /api del mismo dominio.
# VITE_API_URL=/api
# Desarrollo local típico:
# VITE_API_URL=http://127.0.0.1:8000

# WhatsApp barbería: solo dígitos internacionales (ej. 59899611465). Etiqueta visible opcional.
# VITE_WHATSAPP_TURNO=59899611465
# VITE_WHATSAPP_TURNO_LABEL=099 611 465

# Enlace a ayuda Mercado Pago (devoluciones / solicitar reembolso).
# VITE_MP_REEMBOLSO_URL=https://www.mercadopago.com.uy/ayuda
